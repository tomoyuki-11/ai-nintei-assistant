# ──────────────────────────────────────────────────────────
# 必須：Anthropic Claude API キー
# 取得先: https://console.anthropic.com/
# ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-ここに自分のAPIキーを貼り付ける

# ──────────────────────────────────────────────────────────
# 任意：OpenAI Whisper API キー（音声文字起こし精度向上）
# 取得先: https://platform.openai.com/api-keys
# 設定しない場合は音声認識が利用できません
# ──────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ──────────────────────────────────────────────────────────
# 任意：セキュリティ設定（変更推奨）
# ──────────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-in-production
SUPERADMIN_PASSWORD=superadmin1234

# ──────────────────────────────────────────────────────────
# 任意：Stripe 決済設定（テスト用キー記載済み・そのまま使えます）
# ──────────────────────────────────────────────────────────
# Stripe シークレットキーはGitHubのシークレットスキャンに引っかかるため直接記載できません
# Stripeダッシュボード → 開発者 → APIキー からコピーしてください
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=pk_test_51ToOyx2Nic57HJAKmKL4mDWa4fIHXNlTFHH1l83NZHIVuDD0CYvqnWgmTBX0wloZn0Sf3p3TpONRgK8F0bp5J6KW00H6QE4Ezw
# 個人向け価格
STRIPE_INDIVIDUAL_PRICE_ID=price_1TocDT2Nic57HJAKOIaGZ4Py
STRIPE_INDIVIDUAL_CREDIT_PRICE_ID=price_1Tod6X2Nic57HJAK6RxcbouM
# 施設向け価格（将来変更予定・空欄の場合は個人向け価格にフォールバック）
STRIPE_PRICE_ID=
STRIPE_CREDIT_PRICE_ID=
# Webhook シークレットは「stripe listen」実行時に発行されるため空のまま
# 決済のWebhook受信テストをしない場合は空でもOK
STRIPE_WEBHOOK_SECRET=
FRONTEND_URL=http://localhost:3000
